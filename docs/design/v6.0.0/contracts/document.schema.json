{
  "$defs": {
    "Block": {
      "additionalProperties": true,
      "description": "A single parsed document block.\n\nIntentionally permissive \u2014 the ailang-parse Block is a union-shaped\ndataclass and its concrete fields vary by block type. We pin the\ndiscriminator (`type`) and the common `text` field, and bag the rest\ninto `properties` so Firestore round-trip is lossless.",
      "properties": {
        "type": {
          "enum": [
            "heading",
            "paragraph",
            "text",
            "table",
            "image",
            "audio",
            "video",
            "change",
            "list",
            "section"
          ],
          "title": "Type",
          "type": "string"
        },
        "text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text"
        },
        "properties": {
          "type": "object",
          "additionalProperties": true,
          "title": "Properties"
        }
      },
      "required": [
        "type"
      ],
      "title": "Block",
      "type": "object"
    },
