# Aitana Platform v6 — environment variables
#
# Copy to `.env` (gitignored) and fill in for your environment.
# For the zero-config workshop path, set LOCAL_MODE=1 and start `make dev` —
# everything else is optional. See WORKSHOP.md for the graduating-to-cloud
# checklist.

# ----------------------------------------------------------------------------
# LOCAL_MODE — zero-GCP, in-memory workshop tier
# ----------------------------------------------------------------------------
# Backend uses InMemoryFirestoreClient + stub auth; frontend mounts the
# yellow banner and bypasses sign-in. Data resets on every backend restart.
# Mutually exclusive with K_SERVICE / GAE_ENV / KUBERNETES_SERVICE_HOST —
# backend refuses to boot if paired (security guard).
LOCAL_MODE=1
NEXT_PUBLIC_LOCAL_MODE=1
# Optional: persist in-memory Firestore to ~/.aitana-local/firestore.json
# on shutdown so state survives a `make dev` restart. Off by default.
# LOCAL_MODE_PERSIST=0

# ----------------------------------------------------------------------------
# GCP — required when LOCAL_MODE is off
# ----------------------------------------------------------------------------
# GOOGLE_CLOUD_PROJECT=your-project-id
# GCP_PROJECT=your-project-id              # legacy alias, kept for v5 parity

# Vertex AI Agent Engine — persistent sessions + memory
# AGENT_ENGINE_ID=projects/PROJECT/locations/LOCATION/reasoningEngines/ID
# AGENT_ENGINE_STAGING_BUCKET=gs://your-staging-bucket

# ADK artifacts (uploaded docs, intermediate tool outputs)
# ADK_ARTIFACT_BUCKET=gs://your-artifact-bucket

# GCS bucket for raw uploaded documents
# DOCUMENTS_BUCKET=your-documents-bucket

# Cloud Run / GCS logs bucket
# LOGS_BUCKET_NAME=your-logs-bucket

# ----------------------------------------------------------------------------
# Firebase — required when LOCAL_MODE is off (frontend auth + Firestore)
# ----------------------------------------------------------------------------
# Web app config from Firebase Console → Project Settings → Your apps.
# Public web API keys are NOT secrets — security is enforced by Firestore
# rules + auth domain restrictions. See https://firebase.google.com/docs/projects/api-keys
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# ----------------------------------------------------------------------------
# Model providers — pick what your skills use
# ----------------------------------------------------------------------------
# Gemini via Vertex AI (recommended in cloud mode; ADC handles auth)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_LOCATION=europe-west1

# Or Gemini via API key (simpler for dev; unset for Vertex)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=                          # legacy alias

# ----------------------------------------------------------------------------
# Optional services
# ----------------------------------------------------------------------------
# Vertex AI Search datastore (the ai_search tool returns a disabled message
# when unset). Format: projects/PROJECT/locations/LOC/collections/COL/dataStores/ID
# VERTEX_AI_SEARCH_DATASTORE_ID=

# Document parsing (docparse / ailang-parse)
# DOCPARSE_API_KEY=

# ----------------------------------------------------------------------------
# Local dev tuning
# ----------------------------------------------------------------------------
# Force in-memory ADK sessions even when AGENT_ENGINE_ID is set — cuts laptop
# TTFT by avoiding Vertex round-trips. Production unaffected (don't set it).
# AITANA_LOCAL_SESSION=memory

# TTFT instrumentation mode: full | log | off
# AITANA_TTFT_MODE=log

# CORS origins for the backend (comma-separated)
# ALLOW_ORIGINS=http://localhost:3456
