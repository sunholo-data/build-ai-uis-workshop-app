# Frontend environment variables — copy to .env.local for local development.
# Cloud Run injects NEXT_PUBLIC_* vars at build time via Cloud Build substitutions.

# ----------------------------------------------------------------------------
# LOCAL_MODE — zero-GCP workshop tier (recommended first stop)
# ----------------------------------------------------------------------------
# Mounts the LOCAL_MODE banner and bypasses sign-in with a stub workshop
# identity. Pair with backend's LOCAL_MODE=1.
# Leave commented to use the Firebase config below for real auth.
# NEXT_PUBLIC_LOCAL_MODE=1

# --- Optional dev/debug ---
# NEXT_PUBLIC_DEV_LATENCY_HUD=1    # show on-screen TTFT HUD in dev
# NEXT_PUBLIC_SHOW_DEV_PROBES=true # show "My Skills" button on welcome page

# Sandbox URL for MCP-App iframes (sprint 1.7). Defaults to the dev
# deployment when unset; set explicitly for local sandbox testing.
# NEXT_PUBLIC_MCP_SANDBOX_URL=

# --- Firebase ---
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# --- Admin ---
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# --- Chat History (CHAT-HISTORY sprint) ---
# Gate the DocumentHistoryPanel component. Set to "true" to enable.
NEXT_PUBLIC_CHAT_HISTORY_ENABLED=true
