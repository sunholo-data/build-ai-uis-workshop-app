{
  "name": "Build AI UIs Beyond Chat — Workshop",
  "image": "mcr.microsoft.com/devcontainers/base:bookworm",
  "hostRequirements": { "cpus": 2 },
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" }
  },
  "containerEnv": {
    "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "forwardPorts": [3456, 1956, 3457],
  "portsAttributes": {
    "3456": { "label": "Frontend (open this)", "onAutoForward": "openBrowser" },
    "1956": { "label": "Backend API", "onAutoForward": "silent" },
    "3457": { "label": "MCP sandbox", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "dbaeumer.vscode-eslint"]
    }
  }
}
