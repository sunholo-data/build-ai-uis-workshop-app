# Backend environment variables — copy to .env for local development.
# Cloud Run injects these automatically from Secret Manager + build substitutions.

# ----------------------------------------------------------------------------
# LOCAL_MODE — zero-GCP workshop tier (recommended first stop)
# ----------------------------------------------------------------------------
# Backend boots with InMemoryFirestoreClient + stub auth; no GCP credentials
# required. Pair with NEXT_PUBLIC_LOCAL_MODE=1 in frontend/.env.local.
# Mutually exclusive with K_SERVICE / GAE_ENV / KUBERNETES_SERVICE_HOST.
# Leave commented to use the Aitana cloud-mode defaults below.
# LOCAL_MODE=1
# LOCAL_MODE_PERSIST=0      # set to 1 to persist in-memory Firestore between restarts

# --- GCP Core ---
# GCP_PROJECT must be set explicitly to override any shell-level GCP_PROJECT
# inherited from v5 tooling (which points at multivac-internal-dev).
GCP_PROJECT=aitana-multivac-dev
GOOGLE_CLOUD_PROJECT=aitana-multivac-dev
GOOGLE_CLOUD_LOCATION=europe-west1
GOOGLE_GENAI_USE_VERTEXAI=True

# --- ADK Session + Memory (Agent Engine) ---
# Numeric ID of the Vertex AI Agent Engine (Reasoning Engine) resource. Local
# dev should point at dev's engine so laptop chats persist to the same store
# as deployed Cloud Run dev (same pattern as Firebase Auth/Firestore — laptop
# talks to cloud via ADC). Leave unset only when you intentionally want the
# in-memory backend (every uvicorn reload wipes chat history).
#
# Engine IDs (also in docs/ops/deployed-urls.md):
#   dev:  6224370509212024832
#   test: 6388611158122692608
#   prod: 7741942846147526656
AGENT_ENGINE_ID=6224370509212024832

# --- GCS Buckets ---
# Logs + ADK artifact storage. Cloud Run gets this from cloudbuild.yaml substitution
# ({PROJECT_ID}-aitana-v6-logs). Leave unset to use InMemoryArtifactService locally
# (artifacts evaporate on uvicorn auto-reload — same problem as in-memory sessions).
# LOGS_BUCKET_NAME=aitana-multivac-dev-aitana-v6-logs
ADK_ARTIFACT_BUCKET=aitana-multivac-dev-artifacts  # dedicated artifacts bucket (per-env)

# GCS bucket for the file browser tool (list_documents / get_document_content).
# Shared with v5; per-skill overrides go in SkillConfig.tool_configs.list_documents.bucket_url.
# DOCUMENTS_BUCKET=aitana-documents-bucket

# --- Auth ---
FIREBASE_PROJECT_ID=aitana-multivac-dev
# Path to Firebase Admin SDK service account key (local dev only).
# On Cloud Run, ADC is used instead.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Signed URLs ---
# Service account email for GCS signed URL issuance via impersonation.
# Defaults to the Cloud Run SA (ADC) when unset.
# SIGNED_URL_SA_EMAIL=aitana-v6@aitana-multivac-dev.iam.gserviceaccount.com
# Signed URL TTL in seconds (default 900, max 3600).
# SIGNED_URL_TTL_SECONDS=900

# --- API ---
# Comma-separated allowed CORS origins. Unset = no CORS restriction (local dev).
# ALLOW_ORIGINS=https://aitana-v6-frontend-xxx.a.run.app

# --- Chat History (CHAT-HISTORY sprint) ---
# Gate the chat session index endpoints + ADK callbacks.
CHAT_HISTORY_ENABLED=true
# Flash-tier model for auto-generating session titles after turn 2.
CHAT_TITLE_MODEL=gemini-2.5-flash-lite

# --- RAG Documents (RAG-CORPUS sprint v6.3.0) ---
# Enable per-user Vertex AI RAG Engine corpora for document retrieval.
# Requires: Agent Engine (AGENT_ENGINE_ID must be set) and Vertex AI RAG API enabled.
# Default: false — safe for template forks without Agent Engine.
# RAG_DOCUMENTS_ENABLED=false

# --- Vertex AI Search ---
# Discovery Engine datastore used by the ai_search skill tool.
# Project: aitana-ai-search (separate GCP project dedicated to search infra).
# To list available datastores:
#   gcloud alpha discovery-engine data-stores list --project=aitana-ai-search --location=eu
VERTEX_AI_SEARCH_DATASTORE_ID=projects/aitana-ai-search/locations/eu/collections/default_collection/dataStores/aitana3

# --- Channels: Discord (CHANNELS-FRAMEWORK M2) ---
# Discord bot token from https://discord.com/developers/applications
# Required for the gateway connection (mentions + DMs).
# Set min_instances=1 in Cloud Run for the Discord service — gateway
# keepalive drops on cold starts and Discord boots us off.
# DISCORD_TOKEN=
# Application public key (hex) — used to verify Ed25519-signed slash-command
# interaction webhooks at POST /api/discord/webhook.
# DISCORD_PUBLIC_KEY=
# Application ID — used by the slash-command registration helper.
# DISCORD_APPLICATION_ID=

# --- Local dev ports ---
# Backend runs on 1956 (matches frontend proxy expectation).
# Set in Makefile; override here only if you need a different port.
# PORT=1956

# --- Email channel (Mailgun) ---
# Set all four to register the EmailChannel at app boot. Leave unset (the
# default) and the email channel is skipped — useful for local dev without
# Mailgun creds. Production injects these via Secret Manager.
#
# MAILGUN_SIGNING_KEY    — webhook HMAC signing key (Mailgun dashboard → Webhooks)
# MAILGUN_API_KEY        — Mailgun API key for outbound sends
# MAILGUN_DOMAIN         — sending domain (e.g., email.aitana.chat)
# EMAIL_SENDER_ADDRESS   — From: address for outbound replies (e.g., bot@email.aitana.chat)
# MAILGUN_ENDPOINT       — region endpoint, defaults to https://api.eu.mailgun.net
# MAILGUN_SIGNING_KEY=
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# EMAIL_SENDER_ADDRESS=
# MAILGUN_ENDPOINT=https://api.eu.mailgun.net

# ----------------------------------------------------------------------------
# CHANNELS — Telegram (M4)
# ----------------------------------------------------------------------------
# Leave unset and the telegram channel is skipped — useful for local dev
# without a bot. Production injects these via Secret Manager.
#
# TELEGRAM_BOT_TOKEN       — token from BotFather (123456:ABC-DEF...)
# TELEGRAM_WEBHOOK_SECRET  — secret token sent in X-Telegram-Bot-Api-Secret-Token
#                            header; configured via Telegram's setWebhook API
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# CHANNELS — WhatsApp via Twilio (M4)
# ----------------------------------------------------------------------------
# Leave TWILIO_ACCOUNT_SID unset and the whatsapp channel is skipped.
# Twilio sandbox is sufficient for non-prod; real WhatsApp Business approval
# is required for production deployments.
#
# TWILIO_ACCOUNT_SID       — Twilio account SID
# TWILIO_AUTH_TOKEN        — Twilio auth token (used for X-Twilio-Signature verify)
# TWILIO_WHATSAPP_FROM     — bot's WhatsApp number, format `whatsapp:+1415...`
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=

# --- AILANG Parse (document extraction) ---
# API key for ailang-parse deterministic Office/text extraction.
# Required for .docx/.pptx/.xlsx/.epub/.csv etc. to parse without an LLM.
# Get a key at https://ailang.io — store in Secret Manager as DOCPARSE_API_KEY.
# Without this, all uploads land in `pending_ai_extraction` status indefinitely.
# DOCPARSE_API_KEY=
